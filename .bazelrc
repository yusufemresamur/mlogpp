build --cxxopt=-Wall --cxxopt=-Wextra --cxxopt=-Werror
build --cxxopt=-std=c++23

build:coverage --cxxopt='-fprofile-instr-generate' --cxxopt='-fcoverage-mapping' --cxxopt='-O0' --cxxopt='-ftest-coverage' --linkopt='-fprofile-instr-generate'

# GCC toolchain — forces system GCC (local_config_cc defaults to clang on this machine)
build:gcc --extra_toolchains=@local_config_cc_toolchains//:all
build:gcc --repo_env=CC=/usr/bin/gcc
build:gcc --repo_env=CXX=/usr/bin/g++
build:gcc --test_env=COVERAGE_GCOV_PATH=/usr/bin/gcov