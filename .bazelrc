build --cxxopt='-Wall' --cxxopt='-Wextra' --cxxopt='-Werror'
build --cxxopt='-std=c++23'

# GCC toolchain (f0rmiga/gcc-toolchain)
build:gcc --extra_toolchains=@gcc_toolchain_x86_64//:cc_toolchain
build:gcc --dynamic_mode=off
build:gcc --linkopt='-lstdc++'

build:coverage --cxxopt='-fprofile-instr-generate' --cxxopt='-fcoverage-mapping' 
build:coverage --cxxopt='-O0' --cxxopt='-ftest-coverage' --linkopt='-fprofile-instr-generate'
